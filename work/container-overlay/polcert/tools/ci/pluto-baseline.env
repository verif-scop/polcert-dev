# Keep this file aligned with the Dockerfile ARG defaults.
# `PLUTO_IMAGE` is the image currently consumed by PolCert CI.
# `PLUTO_BASELINE_TAG` is the versioned name to use for the next published Pluto base image.
PLUTO_IMAGE=hughshine/pluto-verif:latest
PLUTO_BASELINE_TAG=polcert-pluto-iss-bridge-ac5ea83
PLUTO_VERSIONED_IMAGE=hughshine/pluto-verif:polcert-pluto-iss-bridge-ac5ea83
PLUTO_GIT_REMOTE=https://github.com/verif-scop/pluto.git
PLUTO_GIT_COMMIT=ac5ea8323129655afb283b77684f4d71066c6e79
